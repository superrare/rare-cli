{
  "name": "@rareprotocol/rare-cli",
  "version": "1.0.0",
  "description": "CLI tool for interacting with the RARE protocol smart contracts",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/superrare/rare-cli.git"
  },
  "homepage": "https://github.com/superrare/rare-cli#readme",
  "keywords": [
    "rare",
    "superrare",
    "nft",
    "ethereum",
    "cli",
    "auction",
    "erc721"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js"
    },
    "./client": {
      "import": "./dist/client.js",
      "types": "./dist/client.d.ts"
    }
  },
  "typesVersions": {
    "*": {
      "client": [
        "dist/client.d.ts"
      ]
    }
  },
  "bin": {
    "rare": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "generate:types": "openapi-typescript https://rare-api-8426-784573620320.us-east1.run.app/doc -o src/data-access/schema.d.ts",
    "test": "tsc -p tsconfig.test.json && node --test .test-dist/test/**/*.test.js",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "openapi-fetch": "^0.17.0",
    "viem": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "openapi-typescript": "^7.13.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
