{
  "name": "@rareprotocol/rare-cli",
  "version": "1.0.0",
  "description": "CLI tool for interacting with the RARE protocol smart contracts",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/superrare/rare-cli.git"
  },
  "homepage": "https://github.com/superrare/rare-cli#readme",
  "keywords": [
    "rare",
    "superrare",
    "nft",
    "ethereum",
    "cli",
    "auction",
    "erc721"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js"
    },
    "./client": {
      "import": "./dist/client.js",
      "types": "./dist/client.d.ts"
    }
  },
  "typesVersions": {
    "*": {
      "client": [
        "dist/client.d.ts"
      ]
    }
  },
  "bin": {
    "rare": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "generate:types": "openapi-typescript https://api.superrare.com/doc -o src/data-access/schema.d.ts",
    "test": "npm run build && vitest run --config vitest.config.ts",
    "test:fast": "vitest run test/unit test/integration --config vitest.config.ts",
    "test:coverage": "npm run build && vitest run test/unit test/integration --coverage --config vitest.config.ts",
    "test:e2e:live": "node test/e2e-live/run.mjs",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^12.0.0",
    "openapi-fetch": "^0.17.0",
    "viem": "^2.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "openapi-typescript": "^7.13.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.5"
  }
}
